# Topic Watch — runtime/Docker environment template.
# Copy to `.env` (which is gitignored) and adjust as needed.

# --- Container file permissions (native Linux bind mounts) ---
# Match the bind-mounted ./data ownership to your host user so the container
# can write the database/config. Defaults to 1000 (the typical first Linux
# user). If `id -u`/`id -g` on your host differ, set these to your UID/GID.
PUID=1000
PGID=1000

# --- Timezone ---
# NOTE: not consumed. Both compose files hardcode TZ=UTC, so setting this in
# .env has no effect — the container always runs in UTC. Kept as a placeholder;
# to change the timezone, edit the `TZ=` line in the compose file directly.
TZ=UTC

# --- Web server ---
# Host port published by docker-compose.prod.yml only (container always listens
# on 8000). The default docker-compose.yml used by `make docker-run` hardcodes
# 8000:8000 and ignores this var — it takes effect solely with the prod compose
# file (e.g. `docker compose -f docker-compose.prod.yml up`).
TOPIC_WATCH_PORT=8000

# --- LLM configuration (overrides data/config.yml) ---
# LiteLLM model string and API key for the LLM provider.
TOPIC_WATCH_LLM__MODEL=openai/gpt-4o-mini
TOPIC_WATCH_LLM__API_KEY=your-api-key-here

# --- Security (remote / public deployments) ---
# Only send cookies over HTTPS. Uncomment when serving behind a TLS reverse
# proxy (see SECURITY.md). Leave unset for plain-HTTP localhost use.
# TOPIC_WATCH_SECURE_COOKIES=true
