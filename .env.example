# Topic Watch — runtime/Docker environment template.
# Copy to `.env` (which is gitignored) and adjust as needed.

# --- Container file permissions (native Linux bind mounts) ---
# Match the bind-mounted ./data ownership to your host user so the container
# can write the database/config. Defaults to 1000 (the typical first Linux
# user). If `id -u`/`id -g` on your host differ, set these to your UID/GID.
PUID=1000
PGID=1000

# --- Timezone ---
# IANA timezone for log timestamps and scheduling (e.g. America/New_York).
TZ=UTC

# --- Web server ---
# Host port published by docker-compose.prod.yml (container always listens on 8000).
TOPIC_WATCH_PORT=8000

# --- LLM configuration (overrides data/config.yml) ---
# LiteLLM model string and API key for the LLM provider.
TOPIC_WATCH_LLM__MODEL=openai/gpt-4o-mini
TOPIC_WATCH_LLM__API_KEY=your-api-key-here
